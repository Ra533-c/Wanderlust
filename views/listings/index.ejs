<% layout("/layouts/boilerplates.ejs") %>
    <% block("title" ,"All Listings") %>

        <body>

            <!-- <h3 class="text-center mt-3 mb-3">All Listings</h3> -->
            <style>
                .filter-bar {
                    background: rgba(255, 255, 255, 0.4);
                    width: 100%;
                    backdrop-filter: blur(8px);
                    -webkit-backdrop-filter: blur(8px);
                    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    gap: 1rem;
                    /* Ensures a minimum gap of 2rem between items */
                    position: sticky;
                    top: 56px;
                    z-index: 10;
                    padding: 10px 24px;
                    border-bottom: 1px solid #f0f0f0;
                }

                #filters {
                    flex: 1;
                    /* ← YE ADD KARNA HAI! Available space le lega */
                    min-width: 0;
                    /* ← YE ADD KARNA HAI! Flex overflow allow karega */
                    display: flex;
                    flex-wrap: nowrap;
                    /* Items ko ek hi line mein rakhega */
                    overflow-x: auto;
                    /* Horizontal scroll enable karega */
                }

                .filter {
                    text-align: center;
                    margin-right: 1.5rem;
                    opacity: 0.7;
                    padding: 6px 0;
                }

                .filter:hover {
                    opacity: 1;
                    cursor: pointer;
                }

                /* ADD this new rule for Airbnb-style underline effect */
                .filter::after {
                    content: '';
                    display: block;
                    width: 0;
                    height: 2px;
                    background: #222;
                    transition: width 0.3s ease;
                    margin-top: 4px;
                }

                .filter:hover::after {
                    width: 100%;
                }

                .filter i {
                    font-size: 0.6rem;
                    display: block;
                    color: #717171;
                }

                .filter p {
                    font-size: 0.6rem;
                    margin-top: 2px;
                    margin-bottom: 0
                }

                #filters a {
                    text-decoration: none;
                    color: inherit;
                }

                .tax-toggle {
                    border: 1px solid #e0e0e0;
                    padding: 0.4rem 0.8rem;
                    border-radius: 12px;
                    white-space: nowrap;
                    /* ← Text wrap NAHI hoga! */
                    flex-shrink: 0;
                    /* ← Compress nahi hoga! */
                    font-size: 0.75rem;
                    /* ← Chhota text */
                }

                #filters::-webkit-scrollbar {
                    display: none;
                    /* Chrome/Safari me scrollbar hide */
                }


                @media (max-width: 768px) {
                    .filter-bar {
                        padding: 4px 6px;
                        gap: 0.5rem;
                        width: 100%;
                    }

                    .filter {
                        margin-right: 1rem;
                    }

                    .filter i {
                        font-size: 0.4rem;
                    }

                    .filter p {
                        font-size: 0.4rem;
                    }

                    .tax-toggle {
                        font-size: 0.65rem;
                        padding: 0.3rem 0.6rem;
                    }
                }

                @media (max-width: 425px) {
                    .tax-toggle {
                        display: none;
                    }
                }

                .taxInfo {
                    display: none;
                }
            </style>

            <div class="filter-bar">
                <div id="filters">

                    <a href="/listing">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-globe"></i>
                                <p>All</p>
                            </div>
                        </div>
                    </a>

                    <a href="/listing?category=trending">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-fire"></i>
                                <p>Trending</p>
                            </div>
                        </div>
                    </a>

                    <a href="/listing?category=iconic cities">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-mountain-city"></i>
                                <p>Iconic Cities</p>
                            </div>
                        </div>
                    </a>

                    <a href="/listing?category=mountains">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-mountain"></i>
                                <p>Mountains</p>
                            </div>
                        </div>
                    </a>

                    <a href="/listing?category=castles">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-chess-rook"></i>
                                <p>Castles</p>
                            </div>
                        </div>
                    </a>

                    <a href="/listing?category=camping">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-campground"></i>
                                <p>Camping</p>
                            </div>
                        </div>
                    </a>

                    <a href="/listing?category=amazing pools">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-person-swimming"></i>
                                <p>Amazing Pools</p>
                            </div>
                        </div>
                    </a>

                    <a href="/listing?category=farms">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-cow"></i>
                                <p>Farms</p>
                            </div>
                        </div>
                    </a>

                    <a href="/listing?category=others">
                        <div class="filter">
                            <div>
                                <i class="fa-solid fa-shuffle"></i>
                                <p>Others</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="tax-toggle">
                    <div class="form-check form-switch form-check-reverse d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                        <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
                    </div>
                </div>
            </div>

            <!--<form action="/listing/new" method="GET">
                        <button>Create New Listing</button>
            </form> -->

            <div class="row row-cols-lg-3 row-cols-md-3 mt-3 row-cols-sm-1 row-cols-1 justify-content-center">
                <% for(let listing of allListings){ %>
                    <div class="card col listing-card border-none group bg-transparent transition-all duration-300 hover:shadow-2xl hover:rounded-3xl rounded-3xl"
                        style="width: 20rem;">
                        <a href="/listing/<%= listing._id %>">
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="Listing image"
                                style="height: 20rem;">
                        </a>
                        <!-- <div class="card-img-overlay">abcd</div> -->
                        <div class="card-body px-1 py-3 group-hover:text-zinc-900">
                            <p class="card-text">
                                <b class="text-lg block text-zinc-800">
                                    <%= listing.title %>
                                </b>
                                <span class="text-zinc-600 font-medium">
                                    &#8377;<%= listing.prize.toLocaleString("en-IN") %> <span
                                            class="font-normal">/night</span>
                                </span>
                                <i class="taxInfo text-red-500 font-semibold italic text-sm">&nbsp;+18% GST</i>
                                <br>
                                <span class="text-zinc-500 text-sm line-clamp-1 mt-1">
                                    <%= listing.description %>
                                </span>
                            </p>
                        </div>
                    </div>
                    <% } %>
            </div>

            <!-- to print all listing => -->
            <!-- <ul>
                        <% for(let listing of allListings){ %>
                            <li><a href="/listing/<%=listing._id%>">
                                    <%= listing.title %>
                                </a></li>
                            <% } %>
                    </ul> -->
        </body>



        <script>
            let taxSwitch = document.getElementById("flexSwitchCheckDefault");
            taxSwitch.addEventListener("click", () => {
                let taxInfo = document.getElementsByClassName("taxInfo");
                for (info of taxInfo) {
                    if (info.style.display != "inline") {
                        info.style.display = "inline";
                    } else {
                        info.style.display = "none";
                    }
                }
            });
        </script>